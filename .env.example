# NEXT_PUBLIC_LD_CLIENT_KEY (LD dashboard → Test env → Client-side ID)
NEXT_PUBLIC_LD_CLIENT_KEY=your-ld-client-key-here

# LD_SERVER_KEY (LD dashboard → Test env → SDK key, starts with sdk-)
LD_SERVER_KEY=your-ld-server-key-here

# GOOGLE_AI_API_KEY (aistudio.google.com → Get free API key)
GOOGLE_AI_API_KEY=your-google-ai-api-key-here